{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "allowImportingTsExtensions": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "src/*": ["./src/*"],
      "types/*": ["../../types/*"]
    }
  },
  "include": [
    "src",
    "../../types",
    "auto-import.ts",
    "auto-imports.d.ts",
    "vite.config.ts"
  ]
}
