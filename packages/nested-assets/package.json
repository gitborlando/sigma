{
  "name": "@gitborlando/vite-plugin-nested-assets",
  "version": "0.1.0",
  "description": "Generate a typed nested asset map from a directory in Vite.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "readme.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gitborlando/sigma.git",
    "directory": "packages/nested-assets"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vite": "^7.3.5"
  },
  "peerDependencies": {
    "prettier": "^3.0.0",
    "vite": "^7.0.0"
  }
}
