{
  "name": "sigma",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @sigma/web dev",
    "build": "pnpm --filter @sigma/web build",
    "preview": "pnpm --filter @sigma/web preview",
    "edgeone": "pnpm --filter @sigma/web edgeone",
    "bench:traverser": "pnpm --filter @sigma/web bench:traverser",
    "gen:assets": "pnpm --filter @sigma/web gen:assets",
    "gen:supabase-types": "pnpm --filter @sigma/web gen:supabase-types",
    "prepare": "simple-git-hooks",
    "re-base:main": "git fetch origin main && git rebase origin/main"
  },
  "devDependencies": {
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec pretty-quick --staged"
  },
  "prettier": {
    "printWidth": 85,
    "jsxBracketSameLine": true,
    "useTabs": false,
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": true
  }
}
