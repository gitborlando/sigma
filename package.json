{
  "name": "sigma",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @sigma/web dev",
    "dev:web": "pnpm --filter @sigma/web dev",
    "build": "pnpm --filter @sigma/web build",
    "build:web": "pnpm --filter @sigma/web build",
    "preview": "pnpm --filter @sigma/web preview",
    "preview:web": "pnpm --filter @sigma/web preview",
    "typecheck": "pnpm -r --if-present typecheck",
    "typecheck:web": "pnpm --filter @sigma/web typecheck",
    "edgeone": "pnpm --filter @sigma/web edgeone",
    "gen:supabase-types": "pnpm --filter @sigma/web gen:supabase-types",
    "prepare": "simple-git-hooks",
    "re-base:main": "git fetch origin main && git rebase origin/main"
  },
  "devDependencies": {
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec pretty-quick --staged"
  },
  "prettier": {
    "printWidth": 85,
    "jsxBracketSameLine": true,
    "useTabs": false,
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": true
  }
}
